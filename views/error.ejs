<%- include('partials/head', { title: 'Error' }) %>
<%- include('partials/nav') %>

<div class="page" style="text-align:center;padding-top:48px">
  <div style="font-size:4em;margin-bottom:12px">&#128293;</div>
  <h1 style="color:var(--red)"><%= status || 500 %> — <%= title || 'Something went wrong' %></h1>
  <p style="color:var(--muted);margin:16px 0"><%= message || 'An unexpected error occurred.' %></p>
  <div style="margin-top:28px;display:flex;gap:14px;justify-content:center">
    <a href="/" class="btn btn-red">Back to Menu</a>
    <a href="javascript:history.back()" class="btn btn-ghost">Go Back</a>
  </div>
</div>

<%- include('partials/foot') %>
