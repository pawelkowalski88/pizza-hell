<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= title %> | PizzaLand</title>
<style>
  :root {
    --red:#c0392b; --red-dark:#96281b; --green:#27ae60; --green-dark:#1e8449;
    --orange:#e67e22; --yellow:#f39c12; --bg:#fff8f0; --card:#fff;
    --border:#e8e0d8; --text:#333; --muted:#888; --radius:8px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* NAV */
  .nav { background: var(--red); display: flex; align-items: center; padding: 0 24px; height: 52px; gap: 20px; }
  .nav-brand { color: #fff; font-size: 1.2em; font-weight: bold; }
  .nav-brand:hover { text-decoration: none; }
  .nav a { color: rgba(255,255,255,.85); font-size: .95em; }
  .nav a:hover { color: #fff; text-decoration: none; }
  .nav-spacer { flex: 1; }

  /* HAPPY HOUR BANNER */
  .hh-banner {
    background: linear-gradient(135deg, var(--yellow), var(--orange));
    color: #fff; padding: 10px 24px; text-align: center; font-weight: bold;
    display: flex; align-items: center; justify-content: center; gap: 12px; font-size: .97em;
  }
  .hh-countdown { font-size: 1.1em; font-weight: bold; font-variant-numeric: tabular-nums; }

  /* PAGE WRAPPER */
  .page { max-width: 1000px; margin: 0 auto; padding: 28px 20px; }
  h1 { color: var(--red); margin-bottom: 18px; }
  h2 { color: #444; margin: 22px 0 12px; }

  /* CATEGORY NAV */
  .cat-nav { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .cat-nav a {
    padding: 7px 16px; border-radius: 20px; border: 2px solid var(--border);
    background: #fff; color: var(--text); font-size: .9em; transition: all .15s;
  }
  .cat-nav a:hover, .cat-nav a.active { background: var(--red); border-color: var(--red); color: #fff; text-decoration: none; }

  /* PIZZA GRID */
  .pizza-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .pizza-card {
    background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 16px; display: flex; flex-direction: column; gap: 6px;
  }
  .pizza-card.hh-active { border-color: var(--orange); box-shadow: 0 0 0 2px rgba(230,126,34,.18); }
  .pizza-name { font-size: 1.1em; font-weight: bold; color: var(--red); }
  .pizza-desc { font-size: .88em; color: #555; }
  .pizza-toppings { font-size: .82em; color: var(--muted); }
  .stars { color: var(--yellow); letter-spacing: 2px; font-size: .9em; }
  .price-block { margin-top: 4px; }
  .price-original { text-decoration: line-through; color: var(--muted); font-size: .9em; margin-right: 6px; }
  .price-current { color: var(--green); font-weight: bold; font-size: 1.05em; }
  .price-hh-badge {
    display: inline-block; background: var(--orange); color: #fff; font-size: .75em;
    padding: 1px 7px; border-radius: 10px; margin-left: 4px; vertical-align: middle;
  }
  .add-form { margin-top: 10px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .add-form select, .add-form input[type=number] {
    padding: 5px 8px; border: 1px solid var(--border); border-radius: 4px; font-size: .9em;
  }

  /* BUTTONS */
  .btn { display: inline-block; padding: 8px 18px; border-radius: 4px; border: none; cursor: pointer; font-size: .95em; font-family: inherit; transition: background .15s; }
  .btn-red   { background: var(--red);   color: #fff; }
  .btn-red:hover   { background: var(--red-dark); }
  .btn-green { background: var(--green); color: #fff; }
  .btn-green:hover { background: var(--green-dark); }
  .btn-sm    { padding: 4px 10px; font-size: .82em; }
  .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text); }
  .btn-ghost:hover { background: #f0e8e0; }

  /* CART / TABLE */
  table { width: 100%; border-collapse: collapse; margin: 12px 0; }
  th, td { padding: 9px 10px; border-bottom: 1px solid var(--border); text-align: left; font-size: .93em; }
  th { background: #f5efea; font-weight: 600; }
  .totals-table { width: auto; min-width: 280px; margin-left: auto; }
  .totals-table td, .totals-table th { padding: 6px 12px; border: none; }
  .total-row th { font-size: 1.1em; color: var(--green); }

  /* FORMS */
  .form-group { margin-bottom: 14px; }
  .form-group label { display: block; font-weight: 600; margin-bottom: 4px; font-size: .93em; }
  .form-group input, .form-group textarea, .form-group select {
    width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 4px;
    font-size: .95em; font-family: inherit; background: #fff;
  }
  .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
    outline: 2px solid var(--red); border-color: var(--red);
  }
  .form-row { display: flex; gap: 14px; }
  .form-row .form-group { flex: 1; }
  .payment-section { border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-top: 8px; }
  .radio-group { display: flex; gap: 18px; margin-bottom: 14px; }
  .radio-group label { font-weight: normal; cursor: pointer; }

  /* ALERTS */
  .alert { padding: 12px 16px; border-radius: 4px; margin: 12px 0; font-size: .93em; }
  .alert-success { background: #d4edda; border: 1px solid #c3e6cb; color: #155724; }
  .alert-error   { background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; }
  .alert-info    { background: #d1ecf1; border: 1px solid #bee5eb; color: #0c5460; }

  /* CONFIRMATION BOX */
  .confirm-box { background: #d4edda; border: 2px solid #28a745; border-radius: var(--radius); padding: 24px; text-align: center; margin: 20px 0; }
  .confirm-box h1 { color: #155724; }

  /* ADMIN */
  .admin-nav { display: flex; gap: 12px; margin-bottom: 22px; flex-wrap: wrap; }
  .stat-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; margin-bottom: 24px; }
  .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; text-align: center; }
  .stat-card .stat-num { font-size: 2em; font-weight: bold; color: var(--red); }
  .stat-card .stat-label { font-size: .85em; color: var(--muted); margin-top: 2px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: .78em; font-weight: 600; }
  .badge-green  { background: #d4edda; color: #155724; }
  .badge-red    { background: #f8d7da; color: #721c24; }
  .badge-orange { background: #fff3cd; color: #856404; }
  .hh-day-check { display: inline-flex; gap: 2px; flex-wrap: wrap; }
  .hh-day-check label { font-size: .82em; cursor: pointer; font-weight: normal; }

  /* FOOTER */
  .footer { text-align: center; color: var(--muted); font-size: .8em; padding: 30px 0 20px; border-top: 1px solid var(--border); margin-top: 40px; }
</style>
</head>
<body>
