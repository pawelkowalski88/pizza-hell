<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="page">
  <h1>Our Menu</h1>

  <div class="cat-nav">
    <a href="/">All</a>
    <% for (var i = 0; i < categoryOrder.length; i++) {
         var cat = categoryOrder[i];
         if (menu[cat]) { %>
      <a href="/menu/<%= cat %>"><%= categoryNames[cat] %></a>
    <% } } %>
  </div>

  <% for (var ci = 0; ci < categoryOrder.length; ci++) {
       var catKey   = categoryOrder[ci];
       var catPizzas = menu[catKey];
       if (!catPizzas || catPizzas.length === 0) continue;
       var isHHCat = locals.happyHour && (
           happyHour.applicableCategories.includes('all') ||
           happyHour.applicableCategories.includes(catKey)
       );
  %>
  <div id="cat-<%= catKey %>">
    <h2>
      <%= categoryNames[catKey] %>
      <% if (isHHCat) { %><span class="price-hh-badge">&#127775; HH <%= happyHour.discountPercent %>% off</span><% } %>
    </h2>
    <div class="pizza-grid">
      <% for (var pi = 0; pi < catPizzas.length; pi++) {
           var p = catPizzas[pi];
           var hhPrice = isHHCat ? Math.round(p.basePrice * (1 - happyHour.discountPercent / 100) * 100) / 100 : null;
      %>
      <div class="pizza-card <%= isHHCat ? 'hh-active' : '' %>">
        <div class="pizza-name"><%= p.name %></div>
        <div class="pizza-desc"><%= p.description %></div>
        <div class="pizza-toppings">Toppings: <%= p.toppings.join(', ') %></div>
        <div class="stars">
          <% for (var s = 0; s < Math.floor(p.rating); s++) { %>&#9733;<% } %>
          <% for (var s = Math.floor(p.rating); s < 5; s++) { %>&#9734;<% } %>
          <span style="color:var(--muted);font-size:.82em"> (<%= p.ratingCount %>)</span>
        </div>
        <div class="price-block">
          <% if (hhPrice) { %>
            <span class="price-original">$<%= p.basePrice.toFixed(2) %></span>
            <span class="price-current">$<%= hhPrice.toFixed(2) %></span>
            <span class="price-hh-badge">HH</span>
          <% } else { %>
            <span class="price-current">$<%= p.basePrice.toFixed(2) %></span>
          <% } %>
        </div>
        <form action="/cart/add" method="POST" class="add-form">
          <input type="hidden" name="pizzaId"       value="<%= p._id %>">
          <input type="hidden" name="pizzaCategory" value="<%= p.category %>">
          <select name="size">
            <option value="small">Small&nbsp;$<%= (p.basePrice * 0.8).toFixed(2) %></option>
            <option value="medium" selected>Medium&nbsp;$<%= p.basePrice.toFixed(2) %></option>
            <option value="large">Large&nbsp;$<%= (p.basePrice * 1.3).toFixed(2) %></option>
          </select>
          <input type="number" name="quantity" value="1" min="1" max="10" style="width:52px">
          <button type="submit" class="btn btn-red btn-sm">Add to Cart</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
  <% } %>
</div>

<%- include('../partials/foot') %>
